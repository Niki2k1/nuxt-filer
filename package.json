{
  "name": "nuxt-filer",
  "version": "0.0.5",
  "description": "File storage module for Nuxt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Niki2k1/nuxt-filer.git"
  },
  "homepage": "https://github.com/Niki2k1/nuxt-filer#readme",
  "bugs": {
    "url": "https://github.com/Niki2k1/nuxt-filer/issues"
  },
  "license": "MIT",
  "author": "Niki2k1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./runtime/types": {
      "types": "./src/runtime/types.ts",
      "import": "./src/runtime/types.ts",
      "default": "./src/runtime/types.ts"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist",
    "src/runtime"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "consola": "^3.4.2",
    "defu": "^6.1.4"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "eslint": "^10.1.0",
    "ipx": "^3.1.1",
    "nuxt": "^4.4.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "@nuxt/image": "^2.0.0",
    "ipx": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/image": {
      "optional": true
    },
    "ipx": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
